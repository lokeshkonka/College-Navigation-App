{
  "name": "college-navigation-app",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build:web": "expo export --platform web",
    "qa:full": "npm run lint && npm run typecheck && npm run test && npm run build:web",
    "release:check": "bash scripts/release/check-release.sh",
    "build:apk": "npx eas-cli build --platform android --profile preview",
    "build:list": "npx eas-cli build:list --platform android --limit 5"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@hookform/resolvers": "^3.9.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.49.8",
    "@tanstack/react-query": "^5.62.8",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.13",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.54.2",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "zod": "^3.24.2",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "~19.1.10",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.1",
    "typescript": "~5.9.2",
    "vitest": "^3.1.1"
  }
}
