{
  "name": "college-navigation-app",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build:web": "expo export --platform web",
    "qa:full": "npm run lint && npm run typecheck && npm run test && npm run build:web",
    "release:check": "bash scripts/release/check-release.sh",
    "build:apk": "npx eas-cli build --platform android --profile preview",
    "build:list": "npx eas-cli build:list --platform android --limit 5"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@supabase/supabase-js": "^2.49.8",
    "@tanstack/react-query": "^5.62.8",
    "expo": "~53.0.11",
    "expo-constants": "~17.1.8",
    "expo-image-picker": "~16.1.4",
    "expo-linking": "~7.1.7",
    "expo-location": "~18.1.6",
    "expo-notifications": "~0.31.5",
    "expo-router": "~5.1.11",
    "expo-status-bar": "~2.2.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-hook-form": "^7.54.2",
    "react-native": "0.79.6",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-web": "^0.20.0",
    "zod": "^3.24.2",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "~19.0.10",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^9.24.0",
    "eslint-config-prettier": "^10.1.1",
    "typescript": "~5.8.3",
    "vitest": "^3.1.1"
  }
}
